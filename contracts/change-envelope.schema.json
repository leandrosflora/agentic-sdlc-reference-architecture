{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/change-envelope.schema.json",
  "title": "Agentic SDLC change envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_id", "project_id", "requirement", "risk", "acceptance_criteria", "rollback"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "change_id": { "type": "string", "pattern": "^CHG-[0-9]{4,}$" },
    "project_id": { "type": "string", "minLength": 1 },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "title", "owner"],
      "properties": {
        "source": { "type": "string", "format": "uri" },
        "title": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 }
      }
    },
    "risk": { "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "uri", "sha256"],
        "properties": {
          "kind": { "type": "string" },
          "uri": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "verified"],
      "properties": {
        "strategy": { "type": "string", "minLength": 1 },
        "verified": { "type": "boolean" }
      }
    }
  }
}
