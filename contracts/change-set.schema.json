{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/change-set.schema.json",
  "title": "Multi-repository change set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_set_id",
    "change_id",
    "project_id",
    "risk",
    "repositories",
    "deployment_order",
    "rollback"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "change_set_id": {
      "type": "string",
      "pattern": "^CSET-[0-9]{4,}$"
    },
    "change_id": {
      "type": "string",
      "pattern": "^CHG-[0-9]{4,}$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "repository",
          "component",
          "base_ref",
          "head_ref",
          "depends_on",
          "artifact"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "repository": {
            "type": "string",
            "minLength": 1
          },
          "component": {
            "type": "string",
            "minLength": 1
          },
          "base_ref": {
            "type": "string",
            "minLength": 1
          },
          "head_ref": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifact": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "uri",
              "digest"
            ],
            "properties": {
              "uri": {
                "type": "string",
                "minLength": 1
              },
              "digest": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "deployment_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "verified",
        "order"
      ],
      "properties": {
        "mode": {
          "enum": [
            "atomic",
            "coordinated",
            "independent"
          ]
        },
        "verified": {
          "type": "boolean"
        },
        "order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
