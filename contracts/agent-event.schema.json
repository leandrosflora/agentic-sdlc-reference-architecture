{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/agent-event.schema.json",
  "title": "Agent execution event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "timestamp", "trace_id", "change_id", "project_id", "workflow", "actor", "action", "policy", "usage", "evidence_refs"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "event_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "trace_id": { "type": "string", "minLength": 16 },
    "change_id": { "type": "string", "pattern": "^CHG-[0-9]{4,}$" },
    "project_id": { "type": "string", "minLength": 1 },
    "workflow": {
      "type": "object",
      "required": ["id", "version"],
      "properties": { "id": { "type": "string" }, "version": { "type": "string" } },
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "required": ["type", "id", "version"],
      "properties": {
        "type": { "enum": ["agent", "human", "service"] },
        "id": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "action": { "type": "string", "minLength": 1 },
    "policy": {
      "type": "object",
      "required": ["decision", "bundle_version"],
      "properties": {
        "decision": { "enum": ["allow", "deny", "require_approval"] },
        "bundle_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "usage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "cost_usd"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "evidence_refs": { "type": "array", "items": { "type": "string" } }
  }
}
